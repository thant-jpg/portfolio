---
const year = new Date().getFullYear()
---

<footer class="mt-32">
  <div class="max-w-4xl mx-auto px-8 md:px-12">
    <div class="ornament py-6">&loz;&ensp;&bull;&ensp;&loz;</div>
    <hr class="rule-dark" />
    <div class="py-10 flex items-end justify-between">
      <div>
        <p class="text-sm text-[var(--color-ink-faint)]" style="font-family: var(--font-serif); font-style: italic;">
          &copy; {year}
        </p>
      </div>
      <div class="text-right">
        <p class="text-sm text-[var(--color-ink-faint)]" style="font-family: var(--font-serif); font-style: italic;">
          Set in EB Garamond
        </p>
      </div>
    </div>
  </div>
</footer>
