---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const { title = 'Portfolio', description = 'Architecture Portfolio' } = Astro.props
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh">
    <!-- 80s screw-post binding holes -->
    <div class="binding-holes" aria-hidden="true">
      <div class="binding-hole"></div>
      <div class="binding-hole"></div>
      <div class="binding-hole"></div>
    </div>
    <!-- Drafting page border -->
    <div class="page-border" aria-hidden="true"></div>

    <slot />
  </body>
</html>
